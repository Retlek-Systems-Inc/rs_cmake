include:
  - template: "Workflows/MergeRequest-Pipelines.gitlab-ci.yml"

stages:
  - prepare
#  - build
  - test
  - analyze
# - benchmark
# - deploy

variables:
  CLANG_VER: 22
  DEPS_DIR: .deps
  CLANG_DIR: build
  GCC_DIR: build_gcc
  RPT_DIR: reports
  CCACHE_DIR: ccache

default:
  image: ghcr.io/retlek-systems-inc/rs_cmake/sw-dev:latest
  before_script:
    - eval $(ssh-agent -s)
    - echo "${SSH_PRIVATE_KEY}" | tr -d '\r' | ssh-add -
    - mkdir -p ~/.ssh && chmod 700 ~/.ssh
    - ssh-keyscan gitlab.com >> ~/.ssh/known_hosts
    - chmod 644 ~/.ssh/known_hosts

cache: &global_cache
  key: $CI_COMMIT_REF_SLUG
  paths:
    - $DEPS_DIR
    - $CLANG_DIR
    - $GCC_DIR
    - $CCACHE_DIR
  policy: pull-push

# Common prepare for clang and gcc

#------------------------------------------------------------------------------
prepare:
  stage: prepare
  cache:
    <<: *global_cache
    policy: push          # Only this job writes — all others pull
  script:
    - cmake --preset bootstrap
    - cmake --preset native-clang --fresh
    - cmake --preset native-gcc --fresh

#------------------------------------------------------------------------------
build-and-test:
  stage: test
  needs: [prepare]
  cache:
    <<: *global_cache
    policy: pull
  parallel:
    matrix:
      - PRESET: native-clang-debug
      - PRESET: native-clang-release
      - PRESET: native-clang-asan
        ASAN_OPTIONS: "abort_on_error=1:detect_leaks=1:exitcode=1"
      - PRESET: native-clang-tsan
        TSAN_OPTIONS: "halt_on_error=1:report_signal_unsafe=1:second_deadlock_stack=1:exitcode=1"
      - PRESET: native-clang-ubsan
        UBSAN_OPTIONS: "halt_on_error=1:print_stacktrace=1:exitcode=1"
      - PRESET: native-gcc-debug
      - PRESET: native-gcc-release
      - PRESET: native-gcc-coverage
      - PRESET: native-gcc-valgrind
  script:
    - cmake --workflow --preset $PRESET
    - mkdir -p $RPT_DIR
    - mv $RPT_DIR/junit_test_report.xml $RPT_DIR/${PRESET}_junit_test_report.xml
  after_script:
    # Only runs for coverage — harmless no-op for other presets
    - |
      if [ "$PRESET" = "native-gcc-coverage" ]; then
        mv $GCC_DIR/code-coverage coverage-results
      fi
  artifacts:
    when: always
    reports:
      junit: $RPT_DIR/${PRESET}_junit_test_report.xml
    paths:
      - coverage-results/    # Empty for non-coverage jobs — GitLab ignores missing paths
    expire_in: 1 week

#------------------------------------------------------------------------------
analyze:
  stage: analyze
  needs: [prepare]
  cache:
    <<: *global_cache
    policy: pull
  parallel:
    matrix:
      - PRESET: analysis-clang-tidy
      - PRESET: analysis-cpp-check
      - PRESET: analysis-cpp-lint
  script:
    - scan-build-${CLANG_VER} -o $RPT_DIR/scan-build -k --status-bugs
        -internal-stats --keep-empty
        cmake --workflow --preset $PRESET --fresh
  artifacts:
    when: always
    paths:
      - $RPT_DIR/scan-build/
    expire_in: 1 week
