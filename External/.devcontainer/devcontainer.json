// For format details, see https://aka.ms/devcontainer.json.
// For config options, see the README at:
// https://github.com/microsoft/vscode-dev-containers/tree/v0.205.1/containers/docker-existing-dockerfile
{
    "name": "Retlek Systems CMake Build Env",
    // Sets the run context to one level up instead of the .devcontainer folder.
    "context": "..",
    // Update the 'dockerFile' property if you aren't using the standard 'Dockerfile' filename.
    "dockerFile": "local/Dockerfile",
    "build": {
        "args": {
            "USERNAME": "${localEnv:USER}" // If this doesn't work use your username here
        }
    },
    // Set *default* container specific settings.json values on container create.
    "customizations": {
        "vscode": {
            "settings": {
                "clang-format.executable": "clang-format-20",
                "clang-format.language.cpp.enable": true,
                "C_Cpp.clang_format_sortIncludes": true,
                "C_Cpp.clang_format_path": "clang-format-20",
                "editor.formatOnSave": true,
                "cmake.generator": "Ninja Multi-Config",
                "cmake.setBuildTypeOnMultiConfig": true,
                "testMate.cpp.test.advancedExecutables": [
                    {
                        // For Native Clang builds
                        "pattern": "{build,BUILD}/test/**/*Test_*",
                        "cwd": "${absDirpath}",
                        "env": {
                            "ASAN_OPTIONS": "abort_on_error=1:detect_leaks=1:exitcode=1",
                            "LSAN_OPTIONS": "report_objects=1:verbosity=1",
                            "TSAN_OPTIONS": "halt_on_error=1:report_signal_unsafe=1:second_deadlock_stack=1:exitcode=1",
                            "UBSAN_OPTIONS": "halt_on_error=1:print_stacktrace=1:exitcode=1"
                        }
                    },
                    {
                        // For Dcm Test suite runs.
                        "pattern": "{build,BUILD}/_deps/**/bin/dcm_cpp_test_*",
                        "cwd": "${absDirpath}"
                    },
                    {
                        // For Native GCC builds
                        "pattern": "{build_gcc}/test/**/*Test_*",
                        "cwd": "${absDirpath}"
                    }
                ]
            },
            // Add the IDs of extensions you want installed when the container is created.
            "extensions": [
                "marus25.cortex-debug",
                "cnshenj.vscode-task-manager",
                "ms-vscode.cpptools",
                "ms-vscode.cpptools-extension-pack",
                "ms-vscode.cmake-tools",
                "twxs.cmake",
                "xaver.clang-format",
                "mhutchie.git-graph",
                "matepek.vscode-catch2-test-adapter",
                "hbenl.vscode-test-explorer"
                // "CHIPSAlliance.verible"
            ]
        }
    },
    // Use 'forwardPorts' to make a list of ports inside the container available locally.
    // "forwardPorts": [],
    // Uncomment the next line to run commands after the container is created - for example installing curl.
    // "postCreateCommand": "apt-get update && apt-get install -y curl",
    "runArgs": [
        // For /dev/ttyUSB0
        // "--privileged"
    ],
    "containerEnv": {},
    // Uncomment to use the Docker CLI from inside the container. See https://aka.ms/vscode-remote/samples/docker-from-docker.
    "mounts": [
        "type=bind,consistency=cached,source=${localEnv:HOME}/.ssh,target=${localEnv:HOME}/.ssh" // ,
        // "type=bind,source=/dev/bus/usb,target=/dev/bus/usb",
        // "type=bind,source=/dev/ttyUSB0,target=/dev/ttyUSB0"
    ],
    // "mounts": [ "source=/dev,target=/dev,type=volume" ],
    // Connect as a non-root user: See https://aka.ms/vscode-remote/containers/non-root.
    "remoteUser": "${localEnv:USER}"
}