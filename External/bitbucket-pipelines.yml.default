# The pipelines will scan for report files:
# See: https://support.atlassian.com/bitbucket-cloud/docs/test-reporting-in-pipelines/

image: ghcr.io/retlek-systems-inc/rs_cmake/sw-dev:latest

definitions:
  caches:
    deps:    .deps
    build:   build
    buildgcc: build_gcc
    ccache:  ccache

  steps:
    - step: &prepare
        name: Prepare - Bootstrap and Configure
        script:
          - cmake --preset bootstrap
          - cmake --preset native-clang --fresh
          - cmake --preset native-gcc --fresh
        caches: [deps, build, buildgcc]

    - step: &build_test
        # Override PRESET variable per-use
        script:
          - cmake --workflow --preset $PRESET
          - mv reports/junit_test_report.xml reports/${PRESET}_junit_test_report.xml
        caches: [deps, build, buildgcc, ccache]
        artifacts:
          - reports/${PRESET}_junit_test_report.xml

    - step: &analyze
        script:
          - scan-build-22 -o reports/scan-build -k --status-bugs
              -internal-stats --keep-empty
              cmake --workflow --preset $PRESET --fresh
        caches: [deps, build, ccache]
        artifacts:
          - reports/scan-build/**

pipelines:
  pull-requests:
    "**":
      - step:
          <<: *prepare
      - parallel:
          - step: { <<: *build_test, name: "Clang Debug",   variables: { PRESET: native-clang-debug   } }
          - step: { <<: *build_test, name: "Clang Release", variables: { PRESET: native-clang-release } }
          - step: { <<: *build_test, name: "Clang ASan",    variables: { PRESET: native-clang-asan    },
                    script: [ "ASAN_OPTIONS=abort_on_error=1:detect_leaks=1:exitcode=1 cmake --workflow --preset native-clang-asan",
                               "mv reports/junit_test_report.xml reports/native-clang-asan_junit_test_report.xml" ] }
          - step: { <<: *build_test, name: "Clang TSan",    variables: { PRESET: native-clang-tsan    } }
          - step: { <<: *build_test, name: "Clang UBSan",   variables: { PRESET: native-clang-ubsan   } }
          - step: { <<: *build_test, name: "GCC Debug",     variables: { PRESET: native-gcc-debug     } }
          - step: { <<: *build_test, name: "GCC Release",   variables: { PRESET: native-gcc-release   } }
          - step:
              name: GCC Coverage
              <<: *build_test
              variables: { PRESET: native-gcc-coverage }
              artifacts:
                - reports/native-gcc-coverage_junit_test_report.xml
                - build_gcc/code-coverage/**
          - step: { <<: *analyze, name: "ClangTidy",  variables: { PRESET: analysis-clang-tidy  } }
          - step: { <<: *analyze, name: "CppCheck",   variables: { PRESET: analysis-cpp-check   } }
          - step: { <<: *analyze, name: "CppLint",    variables: { PRESET: analysis-cpp-lint    } }

  branches:
    main:
      # Same as pull-requests - Bitbucket doesn't support YAML anchors across pipeline sections
      # so duplicate the parallel block here or extract to a shared pipeline template.
      - step:
          <<: *prepare
      - parallel:
          - step: { <<: *build_test, name: "Clang Debug",   variables: { PRESET: native-clang-debug   } }
          - step: { <<: *build_test, name: "Clang Release", variables: { PRESET: native-clang-release } }
          - step: { <<: *build_test, name: "Clang ASan",    variables: { PRESET: native-clang-asan    },
                  script: [ "ASAN_OPTIONS=abort_on_error=1:detect_leaks=1:exitcode=1 cmake --workflow --preset native-clang-asan",
                              "mv reports/junit_test_report.xml reports/native-clang-asan_junit_test_report.xml" ] }
          - step: { <<: *build_test, name: "Clang TSan",    variables: { PRESET: native-clang-tsan    } }
          - step: { <<: *build_test, name: "Clang UBSan",   variables: { PRESET: native-clang-ubsan   } }
          - step: { <<: *build_test, name: "GCC Debug",     variables: { PRESET: native-gcc-debug     } }
          - step: { <<: *build_test, name: "GCC Release",   variables: { PRESET: native-gcc-release   } }
          - step:
              name: GCC Coverage
              <<: *build_test
              variables: { PRESET: native-gcc-coverage }
              artifacts:
              - reports/native-gcc-coverage_junit_test_report.xml
              - build_gcc/code-coverage/**
          - step: { <<: *analyze, name: "ClangTidy",  variables: { PRESET: analysis-clang-tidy  } }
          - step: { <<: *analyze, name: "CppCheck",   variables: { PRESET: analysis-cpp-check   } }
          - step: { <<: *analyze, name: "CppLint",    variables: { PRESET: analysis-cpp-lint    } }
